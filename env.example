# 复制为 .env.local 后按需填写

# --- 数据源模式：mock（默认，允许接口内模拟降级）| real（仅真实源）---
DATA_SOURCE_MODE=mock
NEXT_PUBLIC_DATA_SOURCE_MODE=mock

# --- 数据看板真实数据（DATA_SOURCE_MODE=real 时必需）---
# COZE_SUPABASE_URL=
# COZE_SUPABASE_ANON_KEY=

# --- CXCC：通话清单/录音清单及代理 ---
# CXCC_BASE_URL=https://ip:port
# CXCC_AUTH_TOKEN=登录接口返回的 token，请求头字段名 Authentication
# PDF：二十一 …/agentrecordList/api ；二十二 …/selectRecordList/api（多需带 /api 后缀）
# CXCC_AGENT_RECORD_LIST_PATH=/om/agentCalldetailList/selectRecordList/api
# 可选：自签名证书时默认跳过校验；设为 0 则严格校验
# CXCC_INSECURE_SKIP_TLS=1
# 可选：在服务端日志打印 CXCC 请求 URL 与 body（排查无数据）
# CXCC_DEBUG_REQUEST=1

# --- CXCC 登录凭证（用于动态获取 token）---
# CXCC_COMPANY_NAME=广州新瑞
# CXCC_USERNAME=admin
# CXCC_PASSWORD=gzxr147++

# --- 前端 ---
# NEXT_PUBLIC_API_URL=http://localhost:8000
