/* app.wxss */

/* 全局样式 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

/* 容器样式 */
.container {
  padding: 16rpx;
}

/* 卡片样式 */
.card {
  background-color: #fff;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  padding: 24rpx;
  margin-bottom: 16rpx;
}

/* 标题样式 */
.title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

/* 副标题样式 */
.subtitle {
  font-size: 28rpx;
  font-weight: 500;
  color: #666;
  margin-bottom: 12rpx;
}

/* 文本样式 */
.text {
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
}

/* 数据卡片样式 */
.data-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #fff;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  padding: 24rpx;
  margin-bottom: 16rpx;
}

/* 数据值样式 */
.data-value {
  font-size: 40rpx;
  font-weight: 600;
  color: #1890ff;
  margin-bottom: 8rpx;
}

/* 数据标签样式 */
.data-label {
  font-size: 24rpx;
  color: #666;
}

/* 行样式 */
.row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

/* 列样式 */
.col {
  flex: 1;
  margin-right: 16rpx;
}

.col:last-child {
  margin-right: 0;
}

/* 加载样式 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 64rpx 0;
}

/* 错误提示样式 */
.error {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 64rpx 0;
  color: #ff4d4f;
}

/* 图表容器样式 */
.chart-container {
  width: 100%;
  height: 400rpx;
  margin: 16rpx 0;
}

/* 表格样式 */
.table {
  width: 100%;
  border-collapse: collapse;
}

.table th {
  background-color: #f5f5f5;
  padding: 16rpx;
  text-align: left;
  font-size: 24rpx;
  font-weight: 500;
  color: #666;
  border-bottom: 1rpx solid #e8e8e8;
}

.table td {
  padding: 16rpx;
  font-size: 24rpx;
  color: #333;
  border-bottom: 1rpx solid #e8e8e8;
}

.table tr:last-child td {
  border-bottom: none;
}

/* 按钮样式 */
.btn {
  display: block;
  width: 100%;
  padding: 20rpx;
  background-color: #1890ff;
  color: #fff;
  text-align: center;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 500;
  margin-top: 24rpx;
}

/* 日期选择器样式 */
.date-picker {
  margin: 16rpx 0;
  padding: 16rpx;
  background-color: #fff;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}