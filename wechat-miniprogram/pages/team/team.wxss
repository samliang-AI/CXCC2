/* pages/team/team.wxss */
.container {
  padding: 20rpx;
  background-color: #f5f7fa;
  min-height: 100vh;
}

.date-picker {
  background-color: #fff;
  padding: 24rpx 32rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  display: flex;
  align-items: center;
}

.picker {
  font-size: 28rpx;
  color: #1890ff;
  text-align: center;
  font-weight: 600;
}

.row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  width: 100%;
}

.text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 日期选择器文本样式 */
.date-picker text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.date-picker .text {
  color: #1890ff;
  font-weight: 600;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 80rpx 0;
}

.loading text {
  color: #999;
  font-size: 28rpx;
  margin-top: 16rpx;
}

.error {
  background: linear-gradient(135deg, #fff1f0 0%, #ffccc7 100%);
  border-radius: 12rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  color: #cf1322;
  text-align: center;
  font-size: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 77, 79, 0.1);
}

.team-list {
  background-color: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
  padding: 16rpx;
}

.table-container {
  width: 100%;
  background-color: #fafafa;
  border-radius: 12rpx;
  padding: 16rpx;
}

.table-header {
  display: flex;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  font-weight: 600;
  border-radius: 12rpx;
  padding: 20rpx 0;
}

.table-row {
  display: flex;
  border-bottom: 1rpx solid #e8e8e8;
  padding: 20rpx 0;
  transition: background-color 0.2s;
}

.table-row:active {
  background-color: #f0f0f0;
}

.table-row:last-child {
  border-bottom: none;
}

.table-cell {
  flex: 1;
  padding: 0 8rpx;
  text-align: center;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.table-header .table-cell {
  color: #fff;
  font-weight: 600;
}

.table-row .table-cell {
  color: #333;
}

/* 特殊列的宽度调整 */
.table-cell:nth-child(2) {
  flex: 2;
  text-align: left;
  justify-content: flex-start;
}

.table-cell:nth-child(7) {
  color: #ff4d4f;
  font-weight: 700;
}

/* 团队名称样式 */
.table-row .table-cell:nth-child(2) {
  font-weight: 600;
  color: #333;
}
